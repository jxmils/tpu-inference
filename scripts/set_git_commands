# Get mmlu 
pip install -U datasets

python - <<'PY'
import json
from datasets import load_dataset

subjects = [
    "abstract_algebra",
    "anatomy",
    "college_computer_science",   # or "high_school_computer_science"
]

letters = ["A", "B", "C", "D"]
split = "test"
per_subject = 100

for subject in subjects:
    ds = load_dataset("cais/mmlu", subject, split=split)
    out_path = f"mmlu_{subject}.jsonl"

    with open(out_path, "w") as f:
        take = min(per_subject, len(ds))
        for ex in ds.select(range(take)):
            choices = ex["choices"]
            answer_idx = int(ex["answer"])

            prompt = (
                "Answer the following multiple choice question.\n\n"
                f"Subject: {subject}\n"
                f"Question: {ex['question']}\n"
                f"A. {choices[0]}\n"
                f"B. {choices[1]}\n"
                f"C. {choices[2]}\n"
                f"D. {choices[3]}\n\n"
                "Reply with only the correct letter: A, B, C, or D."
            )

            row = {
                "prompt": prompt,
                "output_tokens": 8,
                "metadata": {
                    "subject": subject,
                    "gold_letter": letters[answer_idx],
                    "gold_index": answer_idx,
                },
            }
            f.write(json.dumps(row) + "\n")

    print("wrote", out_path)
PY

vllm bench serve \
  --backend vllm \
