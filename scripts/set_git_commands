# supported models https://docs.vllm.ai/projects/tpu/en/latest/recommended_models_features/#models

export HF_HOME=/dev/shm
# Set HF_TOKEN in your environment before sourcing (do not commit tokens).
export HF_TOKEN="${HF_TOKEN:-}"
export MAX_MODEL_LEN=4096
export TP=8
export VLLM_TORCH_PROFILER_DIR=/workspace/vllm_jax_profiles
mkdir -p "$VLLM_TORCH_PROFILER_DIR"

vllm serve Qwen/Qwen3-30B-A3B-Instruct-2507 \
  --seed 42 \
  --gpu-memory-utilization 0.90 \
  --max-num-batched-tokens 4096 \
  --max-num-seqs 256 \
  --tensor-parallel-size $TP \
  --enable-chunked-prefill \
  --max-model-len $MAX_MODEL_LEN \
  --profiler-config "{\"profiler\":\"torch\",\"torch_profiler_dir\":\"${VLLM_TORCH_PROFILER_DIR}\"}"





