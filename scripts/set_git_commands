from datasets import load_dataset
import json
ds = load_dataset("Aeala/ShareGPT_Vicuna_unfiltered", split="train")
rows = [ds[i] for i in range(min(100_000, len(ds)))]
with open("sharegpt_sample.json", "w", encoding="utf-8") as f:
    json.dump(rows, f)
PY

